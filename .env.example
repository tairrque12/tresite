# Stripe (for payment processing)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Resend (for email notifications)
RESEND_API_KEY=re_...

# Email Configuration
# IMPORTANT: Use your verified domain email for 'from' address
# Example: registrations@yourdomain.com
# If not set, defaults to onboarding@resend.dev (only sends to verified emails)
RESEND_FROM_EMAIL=onboarding@resend.dev

# Tre's email for receiving registration notifications
TRE_EMAIL=cliffstoryiii@gmail.com

# Admin Portal Authentication
ADMIN_EMAIL=cliffstoryiii@gmail.com
ADMIN_PASSWORD=change_this_to_a_secure_password
NEXTAUTH_SECRET=run_openssl_rand_base64_32_to_generate
NEXTAUTH_URL=https://storyssummit.net

# Supabase (for admin dashboard data storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
