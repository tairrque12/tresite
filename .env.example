# Stripe (for payment processing)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Resend (for email notifications)
RESEND_API_KEY=re_...

# Email Configuration
# IMPORTANT: Use your verified domain email for 'from' address
# Example: registrations@yourdomain.com
# If not set, defaults to onboarding@resend.dev (only sends to verified emails)
RESEND_FROM_EMAIL=onboarding@resend.dev

# Tre's email for receiving registration notifications
TRE_EMAIL=cliffstoryiii@gmail.com
